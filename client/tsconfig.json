{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    // this was erroring it out, TS needs this to support JSX
    "jsx": "react-jsx"
  },
  "include": ["src/**/*", "../shared/**/*"],
  "exclude": ["node_modules"]
}